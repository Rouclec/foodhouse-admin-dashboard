{
  "expo": {
    "name": "Foodhouse",
    "slug": "foodhouse",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "foodhouse",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6DCD47",
      "width": 186
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.foodhousecmr.foodhouse",
      "config": {
        "googleMapsApiKey": "AIzaSyCm3xPkE00Y0QEkgVTjAaKkS0pyevGZ1uU"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.foodhousecmr.foodhouse",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "googleMaps": {
        "apiKey": "AIzaSyDuGdaHFlh9PRpIcFTAltiEYQ6UHdpnTxo"
      },
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "$(PRODUCT_NAME) requires access to your camera to take photos for your profile and products."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "$(PRODUCT_NAME) requires access to your photos so you can select photos for your profile and products.",
          "cameraPermission": "$(PRODUCT_NAME) requires access to your camera to take photos for your profile and products."
        }
      ],
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "$(PRODUCT_NAME) uses your location to match you with nearby farmers or buyers and to support home delivery."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      "./plugins/withAndroid15Compatibility.cjs"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2cebe744-985e-4d89-8e7e-5a795ca5c815"
      }
    },
    "owner": "foodhouse_user",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2cebe744-985e-4d89-8e7e-5a795ca5c815"
    },
    "googleSignIn": {
      "webClientId": "167587991754-5ohaq1hmkghc7iaia3cfeumv5nm9fs75.apps.googleusercontent.com",
      "androidClientId": "167587991754-4fpebduab96uq0b8alteq4au25a4ua1l.apps.googleusercontent.com",
      "iosClientId": "167587991754-o3f51jlva90d3tci1kimj5q0flr2ej6q.apps.googleusercontent.com"
    }
  }
}
